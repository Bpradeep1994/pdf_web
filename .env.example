# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-random-64-char-string
ENVIRONMENT=development

# Login security (account lockout)
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_WINDOW=900

# CORS / public URLs
ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
OAUTH_REDIRECT_BASE=http://localhost:8000/api/v1/auth

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
POSTGRES_USER=pdfuser
POSTGRES_PASSWORD=pdfpass
POSTGRES_DB=pdfeditor

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_PASSWORD=redispass

# ──────────────────────────────────────────────
# RabbitMQ
# ──────────────────────────────────────────────
RABBITMQ_USER=pdfuser
RABBITMQ_PASSWORD=pdfpass

# ──────────────────────────────────────────────
# Object Storage (MinIO / AWS S3)
# ──────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
S3_BUCKET=pdf-documents
# Browser-reachable endpoint used to sign download URLs (prod: your S3/CloudFront host)
S3_PUBLIC_ENDPOINT=http://localhost:9000
# DR: bucket for database dumps (backend/scripts/backup.sh)
BACKUP_BUCKET=

# For production AWS S3:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ──────────────────────────────────────────────
# Auth Tokens
# ──────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ──────────────────────────────────────────────
# Email (SMTP)
# ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password

# ──────────────────────────────────────────────
# AI / LLM
# ──────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai          # openai | anthropic
LLM_MODEL=gpt-4o

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small

# ──────────────────────────────────────────────
# Billing (Stripe)
# ──────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Plan price IDs (names must match billing.py)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...

# ──────────────────────────────────────────────
# Frontend
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=${STRIPE_PUBLIC_KEY}

# Trusted rate-limit bypass for CI/test only (leave EMPTY in production)
RATE_LIMIT_BYPASS_TOKEN=
