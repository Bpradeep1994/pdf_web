# ══════════════════════════════════════════════════════════════════════════════
# PRODUCTION environment — copy to `.env.production` and fill the TODOs.
#
#   • The secrets below were freshly generated as a STARTING POINT. Regenerate your
#     own before real use:  python -c "import secrets;print(secrets.token_urlsafe(48))"
#   • NEVER commit the filled-in file. Prefer a secret manager (AWS Secrets Manager,
#     Vault, Doppler) over a plain file on the host.
#   • Anything marked TODO must be set or the corresponding feature stays disabled.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
# Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=__GENERATE_A_64_CHAR_RANDOM_STRING__
ENVIRONMENT=production
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_WINDOW=900

# ── Public URLs (TODO: your real domain) ──────────────────────────────────────
ALLOWED_ORIGINS=https://app.yourdomain.com
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com
OAUTH_REDIRECT_BASE=https://api.yourdomain.com/api/v1/auth
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com

# ── Database (use a MANAGED Postgres with automated backups in prod) ──────────
POSTGRES_USER=pdfuser
POSTGRES_PASSWORD=__GENERATE_A_STRONG_PASSWORD__
POSTGRES_DB=pdfeditor

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=__GENERATE_A_STRONG_PASSWORD__

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=pdfuser
RABBITMQ_PASSWORD=__GENERATE_A_STRONG_PASSWORD__

# ── Object storage (prod: real AWS S3 or a hardened MinIO) ────────────────────
MINIO_ACCESS_KEY=__GENERATE_A_STRONG_KEY__
MINIO_SECRET_KEY=__GENERATE_A_STRONG_SECRET__
S3_BUCKET=pdf-documents
S3_PUBLIC_ENDPOINT=https://cdn.yourdomain.com          # TODO: your S3/CloudFront host
BACKUP_BUCKET=                                          # TODO: bucket for DB dumps
# For real AWS S3 instead of MinIO:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── Tokens ────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email (REQUIRED for verification + password reset) — TODO ─────────────────
# Use a transactional provider: Resend, AWS SES, or Postmark.
SMTP_HOST=                # e.g. smtp.resend.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=no-reply@yourdomain.com

# ── Billing (REQUIRED to charge anyone) — TODO ────────────────────────────────
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=${STRIPE_PUBLIC_KEY}
# ── Razorpay (INDIA — settles to your Indian bank account) — TODO ─────────────
# From the Razorpay dashboard → Settings → API Keys, and Webhooks.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR
# Prices in paise (₹1 = 100 paise). Defaults: ₹299 / ₹999 per month.
RAZORPAY_PRICE_PRO=29900
RAZORPAY_PRICE_BUSINESS=99900

# Optional other providers:
PAYPAL_WEBHOOK_ID=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ── OAuth social login (optional) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── AI / translation (optional) ───────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LIBRETRANSLATE_URL=http://libretranslate:5000

# ── Security ──────────────────────────────────────────────────────────────────
CLAMAV_HOST=clamav            # enable real AV; run `docker compose --profile av up -d`
RATE_LIMIT_REQUESTS=600
RATE_LIMIT_BYPASS_TOKEN=      # MUST be empty in production (dev/CI only)

# ── TLS (Caddy profile) — TODO ────────────────────────────────────────────────
DOMAIN_APP=app.yourdomain.com
DOMAIN_API=api.yourdomain.com
